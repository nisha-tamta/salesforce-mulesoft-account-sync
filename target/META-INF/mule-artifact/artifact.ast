:33},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":107},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":2},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":42},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":107}},"sourceCode":"\u003csub-flow name\u003d\"salesforceLoginSubflow\"\u003e\n\u003clogger level\u003d\"INFO\" message\u003d\"Starting Salesforce SOAP login. correlationId\u003d#[correlationId]\" doc:name\u003d\"Log login start\"\u003e\u003c/logger\u003e\n\u003cee:transform doc:name\u003d\"Build SOAP login request\"\u003e\n\u003cee:message\u003e\n\u003cee:set-payload\u003e\u003c![CDATA[%dw 2.0\noutput application/xml\nns env http://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\n---\nenv#Envelope: {\n  env#Header: {},\n  env#Body: {\n    sf#login: {\n      sf#username: p(\u0027sf.username\u0027),\n      sf#password: p(\u0027sf.password\u0027) ++ p(\u0027sf.token\u0027)\n    }\n  }\n}]]\u003e\u003c/ee:set-payload\u003e\n\u003c/ee:message\u003e\n\u003c/ee:transform\u003e\n\u003clogger level\u003d\"INFO\" message\u003d\"#[\"SOAP request payload \u003d \" ++ write(payload, \"application/xml\")]\" doc:name\u003d\"Log SOAP request payload\"\u003e\u003c/logger\u003e\n\u003chttp:request method\u003d\"POST\" config-ref\u003d\"salesforceRequestConfig\" path\u003d\"/services/Soap/u/60.0\" sendBodyMode\u003d\"ALWAYS\" doc:name\u003d\"SOAP login request\"\u003e\n\u003chttp:headers\u003e\u003c![CDATA[#[{\n                \"Content-Type\": \"text/xml\",\n                \"SOAPAction\": \"login\"\n            }]]]\u003e\u003c/http:headers\u003e\n\u003c/http:request\u003e\n\u003clogger level\u003d\"INFO\" message\u003d\"Salesforce login raw response received. correlationId\u003d#[correlationId]\" doc:name\u003d\"Log login response\"\u003e\u003c/logger\u003e\n\u003cee:transform doc:name\u003d\"Extract session data\"\u003e\n\u003cee:variables\u003e\n\u003cee:set-variable variableName\u003d\"sfSessionId\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\nns soapenv http://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\n---\npayload.soapenv#Envelope.soapenv#Body.sf#loginResponse.sf#result.sf#sessionId as String]]\u003e\u003c/ee:set-variable\u003e\n\u003cee:set-variable variableName\u003d\"sfServerUrl\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\nns soapenv http://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\n---\npayload.soapenv#Envelope.soapenv#Body.sf#loginResponse.sf#result.sf#serverUrl as String]]\u003e\u003c/ee:set-variable\u003e\n\u003cee:set-variable variableName\u003d\"sfHost\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\nns soapenv http://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\nvar serverUrl \u003d payload.soapenv#Envelope.soapenv#Body.sf#loginResponse.sf#result.sf#serverUrl as String\n---\n(serverUrl replace \"https://\" with \"\" splitBy \"/\")[0]]]\u003e\u003c/ee:set-variable\u003e\n\u003c/ee:variables\u003e\n\u003c/ee:transform\u003e\n\u003clogger level\u003d\"INFO\" message\u003d\"Salesforce login successful. host\u003d#[vars.sfHost] correlationId\u003d#[correlationId]\" doc:name\u003d\"Log login success\"\u003e\u003c/logger\u003e\n\u003c/sub-flow\u003e","startColumn":2,"startLine":33},"parameters":[{"unresolvedValue":"salesforceLoginSubflow","metadata":{"docAttributes":{},"endColumn":13,"endLine":107,"fileName":"sf-mule-erp-sync-props.xml","fileUri":"file:/Users/nisha/SPACES/PersonalSpace/Study/MuleSoft/AnypointStudio/studio-workspace/sf-mule-erp-sync-props/src/main/mule/sf-mule-erp-sync-props.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":2},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":13},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":33},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":33},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value"