ttp://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\n---\npayload.soapenv#Envelope.soapenv#Body.sf#loginResponse.sf#result.sf#sessionId as String]]\u003e\u003c/ee:set-variable\u003e\n\u003cee:set-variable variableName\u003d\"sfServerUrl\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\nns soapenv http://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\n---\npayload.soapenv#Envelope.soapenv#Body.sf#loginResponse.sf#result.sf#serverUrl as String]]\u003e\u003c/ee:set-variable\u003e\n\u003cee:set-variable variableName\u003d\"sfHost\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\nns soapenv http://schemas.xmlsoap.org/soap/envelope/\nns sf urn:partner.soap.sforce.com\nvar serverUrl \u003d payload.soapenv#Envelope.soapenv#Body.sf#loginResponse.sf#result.sf#serverUrl as String\n---\n(serverUrl replace \"https://\" with \"\" splitBy \"/\")[0]]]\u003e\u003c/ee:set-variable\u003e\n\u003c/ee:variables\u003e\n\u003c/ee:transform\u003e\n\u003clogger level\u003d\"INFO\" message\u003d\"Salesforce login successful. host\u003d#[vars.sfHost] correlationId\u003d#[correlationId]\" doc:name\u003d\"Log login success\"\u003e\u003c/logger\u003e\n\u003c/sub-flow\u003e","startColumn":2,"startLine":33},"groupModelName":"General","modelName":"name","value":{"aString":"salesforceLoginSubflow"},"defaultValue":false}],"componentId":"salesforceLoginSubflow","extensionModel":{"name":"mule"},"modelName":"subFlow","modelType":"CONSTRUCT","annotations":{}},{"directChildren":[{"directChildren":[],"componentType":"OPERATION","identifier":{"name":"set-variable","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"location":{"name":"queryAccountsSubflow","parts":[{"partPath":"queryAccountsSubflow","partIdentifier":{"identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"SUB_FLOW"}},"fileName":"sf-mule-erp-sync-props.xml","line":109,"column":2},{"partPath":